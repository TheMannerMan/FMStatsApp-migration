@using FMStatsApp.Extensions
@using FMStatsApp.Models
<!DOCTYPE html>
<html lang="en" class="h-100">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FMStatsApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FMStatsApp.styles.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/css/bootstrap/bootstrap.min.css">
    <link rel="stylesheet" href="~/css/bootstrap/navbars-offcanvas.css">
    <link rel="stylesheet" href="~/css/bootstrap/features.css">
    <link rel="stylesheet" href="~/css/bootstrap/grid.css">
    <link rel="stylesheet" href="~/css/bootstrap/sign-in.css">
    <link rel="stylesheet" href="~/css/bootstrap/modals.css">

    <link href="https://cdn.datatables.net/v/dt/jq-3.7.0/dt-2.2.1/b-3.2.1/fh-4.0.1/r-3.0.3/rr-1.5.0/sp-2.3.3/sl-3.0.0/datatables.min.css" rel="stylesheet">
    
    <!-- Font Awesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">FMStatsApp</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">
                                <i class="fas fa-home me-1"></i>FMStatsApp
                            </a>
                        </li>
                        @{
                            var players = Context.Session.GetObjectFromJson<List<Player>>("Players");
                            var hasPlayers = players != null && players.Any();
                        }
                        @if (hasPlayers)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-page="/DisplayPlayers">
                                    <i class="fas fa-users me-1"></i>Players
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-page="/FormationSelecter">
                                    <i class="fas fa-chess-board me-1"></i>Formation Selector
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Bootstrap Javascript -->
    <script src="~/script/bootstrap/bootstrap.bundle.min.js"></script>

    <!-- SeidoAB script helpers -->
    <script src="~/script/seido/modals.js"></script>
    <script src="~/script/seido/select-list-items.js"></script>

    <script src="~/script/custom-handler.js"></script>
    <script src="https://cdn.datatables.net/v/dt/jq-3.7.0/dt-2.2.1/b-3.2.1/fh-4.0.1/r-3.0.3/rr-1.5.0/sp-2.3.3/sl-3.0.0/datatables.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>